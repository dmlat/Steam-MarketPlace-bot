POSTGRES_PORT=5433
POSTGRES_PASSWORD=scanner_dev_password
DATABASE_URL=postgresql+psycopg2://scanner:scanner_dev_password@localhost:5433/steam_scanner

# Rate limiting (seconds between requests)
STEAM_REQUEST_INTERVAL=4.0
STEAM_MAX_RETRIES=5
STEAM_429_MAX_RETRIES=12
STEAM_429_COOLDOWN_SEC=45
STEAM_429_CIRCUIT_THRESHOLD=25
STEAM_NETWORK_MAX_WAIT_SEC=120
STEAM_NETWORK_RETRY_BASE_SEC=5
STEAM_429_CIRCUIT_THRESHOLD=25
STEAM_NETWORK_MAX_WAIT_SEC=120
STEAM_NETWORK_RETRY_BASE_SEC=5
STEAM_NIGHTLY_REQUEST_CAP=10000

# Optional SOCKS5/HTTP proxies (comma-separated, round-robin). Example:
# STEAM_PROXY_URLS=socks5://user:pass@host1:50101,socks5://user:pass@host2:50101
STEAM_PROXY_URLS=socks5://sampleboxmg:WTui7TVksc@161.77.140.25:50101,socks5://sampleboxmg:WTui7TVksc@208.214.164.237:50101,socks5://sampleboxmg:WTui7TVksc@77.47.159.223:50101
STEAM_PROXY_MAX_429=8

# Optional: Steam Web API key for secondary metadata (not required for MVP)
STEAM_WEB_API_KEY=
