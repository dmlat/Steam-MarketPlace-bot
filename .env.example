POSTGRES_PORT=5433
POSTGRES_PASSWORD=scanner_dev_password
DATABASE_URL=postgresql+psycopg2://scanner:scanner_dev_password@localhost:5433/steam_scanner

# Sequential mode (default): round-robin proxies, 8s between requests
STEAM_PARALLEL_WORKERS=1
STEAM_REQUEST_INTERVAL=8.0
STEAM_INTERVAL_PRICE=8.0
STEAM_INTERVAL_SEARCH=15.0
STEAM_INTERVAL_LISTING=25.0
STEAM_INTERVAL_ORDERBOOK=35.0
STEAM_MAX_RETRIES=5
STEAM_429_MAX_RETRIES=2
STEAM_429_COOLDOWN_SEC=120
STEAM_429_CIRCUIT_THRESHOLD=3
STEAM_NETWORK_MAX_WAIT_SEC=120
STEAM_NETWORK_RETRY_BASE_SEC=5
STEAM_NIGHTLY_REQUEST_CAP=10000
STEAM_PROXY_MAX_429=1
STEAM_PROXY_COOLDOWN_HOURS=6

# Optional SOCKS5/HTTP proxies (comma-separated, round-robin)
# STEAM_PROXY_URLS=socks5://user:pass@host1:50101,socks5://user:pass@host2:50101
STEAM_PROXY_URLS=

# Optional: Steam Web API key for secondary metadata (not required for MVP)
STEAM_WEB_API_KEY=
